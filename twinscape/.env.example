# Twinscape — template env. Salin ke `.env` lalu isi nilai asli:
#   cp twinscape/.env.example twinscape/.env
# File `.env` berisi kredensial → TIDAK di-commit (.gitignore). Dibaca otomatis saat `npm start`.

# ── Remote SSH (Fase 1) ───────────────────────────────────────────
REMOTE_ENABLE=0                       # set 1 untuk mengaktifkan fitur remote (tombol Open SSH)
REMOTE_SSH_HOST=                      # IP/host SSH device (BUKAN IP monitoring)
REMOTE_SSH_PORT=22
REMOTE_SSH_USER=                      # username SSH
REMOTE_SSH_PASSWORD=                  # password SSH — ATAU pakai key di bawah
# REMOTE_SSH_KEY_FILE=/path/ke/private_key
# REMOTE_SSH_PASSPHRASE=

# ── Opsional ──────────────────────────────────────────────────────
# V2_PORT=10102
# V2_HOST=127.0.0.1                   # bind localhost saja; hapus = akses dari LAN
# PULSE_SECRET=                       # kunci sesi login; kosong = auto ke twinscape/.pulse-secret
